apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: local-devops-application
  namespace: argocd
spec:
  project: default
  source:
    repoURL: 'https://github.com/kishore19admin/local-devops-lab.git'
    targetRevision: HEAD
    path: k8s-manifests
  destination:
    server: 'https://kubernetes.default.svc'
    namespace: apps
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
